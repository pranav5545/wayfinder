# Frontend env example. Copy to .env.local once the backend is reachable.

# Turn the mock backend off (will hit /api/chat instead).
VITE_USE_MOCK=false

# Optional: if the backend is on a different origin than the Vite dev server,
# set this to the full base URL (e.g. http://localhost:8000).
# Otherwise leave blank and rely on the Vite proxy in vite.config.ts.
VITE_API_BASE=
